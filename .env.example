# Postgres connection string (e.g. Neon or Railway Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# AI provider API keys (server-side only)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Tavily API key for web search in chat (optional; omit to disable web search)
TAVILY_API_KEY=
